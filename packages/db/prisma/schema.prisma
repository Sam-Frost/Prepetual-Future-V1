// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  // output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id Int @id @default(autoincrement())
  username String @unique
  password String 
  availableBalance String @default("0")
  lockedBalance String @default("0")
  orders Order[]
}

model Position {
  id Int @id @default(autoincrement())
  userId Int
  marketId Int 
}

model Fill {
  id Int @id @default(autoincrement())
  maker Int 
  taker Int
  market String
  quantity String
  price String
  long String
  short String
}

model Market{
  id Int @id @default(autoincrement())
  symbol String
  image String
}

model Order {
    id Int @id @default(autoincrement())
    marketId String
    userId Int 
    margin String 
    quantity String 
    price String 
    totalValue String 
    tradeType TradeType 
    orderStatus OrderStatus @default(OPEN)
    orderType OrderType 
    isPostOnly Boolean 
    isReduceOnly Boolean 
    isIoc Boolean 
    user User @relation(fields: [userId], references: [id])
}

  enum TradeType {
    SHORT
    LONG
  }


  enum OrderType {
    MARKET
    LIMIT
  }

enum OrderStatus {
  OPEN
  CANCELLED
  PARTIALLY_FILLED
  FILLED
}